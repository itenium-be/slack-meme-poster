# Local-run config. In production these are split:
#   - non-secret per-tier config  → committed in deploy/dev.env and deploy/prod.env
#   - secret + per-tier host path → set per resource in Coolify (SLACK_BOT_TOKEN, MEMES_DIR)
#   - tier selector               → TIER (dev|prod), picks which deploy/<tier>.env to load
#
# To run locally:  cp .env.sample .env   (docker compose auto-loads .env for ${...})

# Which committed config file to load (deploy/dev.env or deploy/prod.env):
TIER=dev

# Host folder holding the memes (bind-mounted to /memes). Locally, point at ./memes;
# on Coolify this is the NFS-mounted Dropbox path, e.g. /mnt/dropbox/Archive/Funny/Programming.
MEMES_DIR=./memes

# Bot User OAuth Token (xoxb-...). Secret — never commit. See CreateSlackBot.md.
SLACK_BOT_TOKEN=
