# Committed, non-secret config for the DEV tier (pongit).
# Sourced by start.sh (selected by $TIER). Values with spaces MUST be quoted.
# Secrets + per-tier host path live in Coolify: SLACK_BOT_TOKEN, MEMES_DIR.

# Post a meme immediately on (re)deploy — handy while iterating on dev.
POST_MEME_ON_STARTUP=1

TZ=Europe/Brussels
POST_CRON="0 14 * * fri"

# Reddit meme job (leave REDDIT_SUBREDDIT empty to disable):
REDDIT_SUBREDDIT=ProgrammerHumor
REDDIT_POST_CRON="0 9 * * mon"
REDDIT_POST_ON_STARTUP=

# Target Slack channel (a channel id is not a secret). Pongit workspace:
SLACK_CHANNEL_ID=C017FQGNX0X
